# SRP SmartRecruit v3.2 — Production Environment Template
# Copy this to .env on your server and fill in real values.
# NEVER commit .env — only commit this template.

# ── OpenAI / OpenRouter ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini

# ── Database ─────────────────────────────────────────────────────────────
# Docker sets this automatically from docker-compose.yml
# Set only the password here — docker-compose overrides the URL
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Application ──────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
CORS_ORIGINS=https://recruit.srpailabs.com
ALLOWED_HOSTS=recruit.srpailabs.com
ENABLE_LEGACY_COMPAT_ROUTES=false
DB_AUTO_INIT=false

# ── n8n (optional) ───────────────────────────────────────────────────────
N8N_BASE_URL=https://n8n.srpailabs.com
N8N_WEBHOOK_PRODUCTION=https://n8n.srpailabs.com/webhook/YOUR_WEBHOOK_ID

# ── Seeding ──────────────────────────────────────────────────────────────
# Keep disabled in production unless you explicitly need a demo account.
SEED_DEMO=false
