"""
Production .env template for SRP SmartRecruit v3.2
Copy to .env on the Hetzner server and fill in values.
NEVER commit the real .env to version control.
"""

# ============================================================
# REQUIRED — Application will not start without these
# ============================================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# PostgreSQL connection string (Supabase transaction pooler)
DATABASE_URL=postgresql://postgres.YOURPROJECTID:YOURPASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# OpenAI API key
OPENAI_API_KEY=sk-proj-YOURKEYHERE
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# REQUIRED — Environment & Logging
# ============================================================
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# ============================================================
# REQUIRED — CORS (comma-separated list of allowed origins)
# Must match your exact frontend domain. No trailing slash.
# ============================================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================
# OPTIONAL — Email (OTP delivery)
# If not set, OTP will NOT be emailed and registration is dev-only
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ============================================================
# OPTIONAL — n8n workflow automation
# ============================================================
N8N_BASE_URL=https://your-n8n-domain.com
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_PRODUCTION=https://your-n8n-domain.com/webhook/YOUR-WEBHOOK-ID

# ============================================================
# OPTIONAL — Supabase (only if using Supabase JS client features)
# ============================================================
SUPABASE_URL=https://YOURPROJECTID.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============================================================
# JWT settings (defaults are fine, tune as needed)
# ============================================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
OTP_EXPIRE_MINUTES=10
REQUIRE_OTP_ON_LOGIN=False
